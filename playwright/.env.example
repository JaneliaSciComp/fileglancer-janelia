# API key authentication (requires enable_test_api_key=true in the server's config.yaml)
# If FGC_TEST_API_KEY is not set, tests fall back to manual Okta login (global-setup.ts).
FGC_TEST_API_KEY=<key configured on the fileglancer-dev server>

# Your Janelia username — passed to the server as the authenticated user
FGC_TEST_USERNAME=<your Janelia username>
